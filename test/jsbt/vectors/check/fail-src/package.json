{
  "name": "@jsbt-test/check-src",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.mts",
  "exports": {
    ".": {
      "types": "./src/index.d.mts",
      "default": "./src/index.js"
